---
import Layout from "@layouts/Layout.astro";
import CTA from "@components/CTA.astro";

const values = [
  {
    title: "No fluff, just results",
    description: "I skip the slide decks and strategy theater. You get working code, documented pipelines, and dashboards your team actually uses.",
  },
  {
    title: "Built to last",
    description: "I write clean, tested, well-documented code. When the project wraps, your team can maintain and extend everything I built.",
  },
  {
    title: "Startup speed",
    description: "I've worked in startups. I understand the pressure to ship fast without cutting corners on data quality.",
  },
  {
    title: "Full transparency",
    description: "Regular check-ins, clear timelines, and no surprises. You'll always know where things stand.",
  },
];
---

<Layout title="About" description="About Chris McCormick and Glass Walker Development — data engineering and AI consulting.">
  <!-- Header -->
  <section class="bg-surface-dark text-white py-20 md:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <p class="text-sm font-semibold text-brand-400 uppercase tracking-wider">About</p>
      <h1 class="mt-3 text-4xl sm:text-5xl font-bold tracking-tight">
        Meet the founder
      </h1>
    </div>
  </section>

  <!-- Bio -->
  <section class="py-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-20 items-start">
        <!-- Photo -->
        <div class="lg:col-span-2">
          <div class="aspect-[4/5] rounded-2xl bg-slate-100 overflow-hidden border border-slate-200">
            <img
              src="/headshot.jpg"
              alt="Chris McCormick"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>

        <!-- Bio text -->
        <div class="lg:col-span-3">
          <h2 class="text-3xl font-bold text-slate-900">Chris McCormick</h2>
          <p class="mt-1 text-lg text-brand-600 font-medium">Founder & Senior Director</p>

          <div class="mt-6 space-y-5 text-slate-600 leading-relaxed text-lg">
            <p>
              I started Glass Walker Development because I kept seeing the same problem: companies drowning in data but starving for answers. Expensive enterprise platforms that nobody used. Developer time wasted pulling one-off reports. Dashboards that told you what happened last month but not why.
            </p>
            <p>
              With a background spanning tech, finance, and marketing, I bring a unique perspective to data work. I don't just build pipelines — I understand the business questions those pipelines need to answer.
            </p>
            <p>
              I specialize in the Google Cloud ecosystem, particularly BigQuery, Dataform, dbt, and Looker. More recently, I've been building AI-powered applications that help companies automate complex workflows and extract intelligence from their data in ways that weren't possible a few years ago.
            </p>
            <p>
              Glass Walker Development is a woman-owned business based in Lynnwood, WA. I work with companies of all sizes, but I have a particular soft spot for startups and growth-stage companies where good data can be a real competitive advantage.
            </p>
          </div>

          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="/contact"
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-brand-600 text-white font-semibold hover:bg-brand-700 transition-colors text-sm"
            >
              Get in touch
            </a>
            <a
              href="https://github.com/verduranti"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-slate-300 text-slate-700 font-semibold hover:bg-slate-50 transition-colors text-sm"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              GitHub
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-24 bg-slate-50 border-y border-slate-200">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider">How I work</p>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-slate-900">
          What you can expect
        </h2>
      </div>

      <div class="mt-16 grid sm:grid-cols-2 gap-10">
        {values.map((value) => (
          <div>
            <h3 class="text-lg font-bold text-slate-900">{value.title}</h3>
            <p class="mt-2 text-slate-600 leading-relaxed">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</Layout>
