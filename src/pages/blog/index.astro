---
import Layout from "@layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Blog" description="Thoughts on data engineering, analytics, and AI development from Glass Walker Development.">
  <!-- Header -->
  <section class="bg-surface-dark text-white py-20 md:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <p class="text-sm font-semibold text-brand-400 uppercase tracking-wider">Blog</p>
      <h1 class="mt-3 text-4xl sm:text-5xl font-bold tracking-tight">
        Thoughts & guides
      </h1>
      <p class="mt-5 text-lg text-slate-400 max-w-2xl leading-relaxed">
        Practical writing about data engineering, analytics, and building AI applications.
      </p>
    </div>
  </section>

  <section class="py-24">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      {posts.length === 0 ? (
        <p class="text-center text-slate-500 text-lg py-12">
          Posts coming soon. Check back shortly.
        </p>
      ) : (
        <div class="space-y-10">
          {posts.map((post) => (
            <article class="group">
              <a href={`/blog/${post.id}`} class="block">
                <div class="flex items-center gap-3 text-sm text-slate-500">
                  <time datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                  <span class="text-slate-300">&middot;</span>
                  <span class="text-brand-600 font-medium">{post.data.category}</span>
                </div>
                <h2 class="mt-3 text-2xl font-bold text-slate-900 group-hover:text-brand-600 transition-colors">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-slate-600 leading-relaxed">
                  {post.data.description}
                </p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {post.data.tags.map((tag: string) => (
                    <span class="px-2.5 py-1 rounded-md bg-slate-100 text-slate-600 text-xs font-medium">
                      {tag}
                    </span>
                  ))}
                </div>
              </a>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
