---
const services = [
  {
    title: "Data Engineering",
    description: "Production-grade pipelines on BigQuery with Dataform and dbt. Clean, tested, documented transformations that your team can trust.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" /></svg>`,
    tags: ["BigQuery", "Dataform", "dbt"],
    color: "brand",
  },
  {
    title: "Analytics & BI",
    description: "Dashboards and reporting with Looker and Looker Studio that tell the story behind your numbers. Self-service analytics your whole team can use.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>`,
    tags: ["Looker", "Looker Studio", "GA4"],
    color: "accent",
  },
  {
    title: "AI App Development",
    description: "Custom AI applications powered by LLMs and modern ML frameworks. From intelligent assistants to automated workflows — AI that solves real problems.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>`,
    tags: ["LLMs", "Python", "Cloud Functions"],
    color: "violet",
  },
];
---

<section class="py-24 grid-bg">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section header -->
    <div class="max-w-2xl">
      <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider">What I do</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-slate-900">
        End-to-end data and AI solutions
      </h2>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        From raw data to actionable insights to intelligent applications — I cover the full stack so you can focus on growing your business.
      </p>
    </div>

    <!-- Cards -->
    <div class="mt-16 grid md:grid-cols-3 gap-8">
      {services.map((service) => (
        <div class="card-hover rounded-2xl border border-slate-200 bg-white p-8">
          <div class="w-12 h-12 rounded-xl bg-brand-50 text-brand-600 flex items-center justify-center">
            <Fragment set:html={service.icon} />
          </div>
          <h3 class="mt-5 text-xl font-bold text-slate-900">{service.title}</h3>
          <p class="mt-3 text-slate-600 leading-relaxed">{service.description}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {service.tags.map((tag) => (
              <span class="px-2.5 py-1 rounded-md bg-slate-100 text-slate-600 text-xs font-medium">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a href="/services" class="inline-flex items-center gap-2 text-brand-600 font-semibold hover:text-brand-700 transition-colors">
        View all services
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </div>
</section>
